@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Logowanie";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm mt-5">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">Logowanie</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Login</label>
                        <input name="login" class="form-control" placeholder="Wpisz swój login" />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold">Hasło</label>
                        <input type="password" name="password" class="form-control" placeholder="Wpisz hasło" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg">Zaloguj się</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <p class="mb-0">Nie masz konta? <a asp-action="Register">Zarejestruj się</a></p>
            </div>
        </div>
    </div>
</div>