@model Wprawka1.Models.Book

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dodaj</title>
</head>
<body>

<h4>Dodaj książkę</h4>
<hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Title" class="control-label fw-bold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Autorzy</label>
                    <select name="selectedAuthors" class="form-control" asp-items="ViewBag.AuthorIds" multiple="multiple" style="min-height: 100px;"></select>
                    <div class="form-text text-muted d-block mt-1">
                        <em>Przytrzymaj klawisz CTRL, aby zaznaczyć wielu autorów.</em>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="PublisherId" class="control-label fw-bold"></label>
                    <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.PublisherId"></select>
                </div>

                <div class="form-group">
                    <input type="submit" value="Dodaj" class="btn btn-primary w-100" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Powrót do listy</a>
    </div>
</body>
</html>
