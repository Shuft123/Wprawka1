@model Wprawka1.Models.Book

@{
    ViewData["Title"] = "Edytuj książkę";
}

<h2 class="mb-4">Edytuj książkę</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label fw-bold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Autorzy</label>
                <select name="selectedAuthors" class="form-control" asp-items="ViewBag.AuthorIds" multiple="multiple" style="min-height: 100px;"></select>
                <small class="form-text text-muted d-block mt-1">
                    <em>Przytrzymaj klawisz CTRL, aby zaznaczyć lub odznaczyć autorów.</em>
                </small>
            </div>

            <div class="form-group mb-4">
                <label asp-for="PublisherId" class="control-label fw-bold"></label>
                <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.PublisherId"></select>
                <span asp-validation-for="PublisherId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Zapisz zmiany" class="btn btn-success w-100" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Powrót do listy</a>
</div>